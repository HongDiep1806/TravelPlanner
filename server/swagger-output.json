    "/packing/{tripId}": {
      "get": {
        "tags": ["Packing List"],
        "summary": "Get all packing items for a trip",
        "description": "Returns the full packing list for the specified trip.",
        "parameters": [
          {
            "name": "tripId",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "ID of the trip"
          }
        ],
        "responses": {
          "200": {
            "description": "List of packing items"
          },
          "404": {
            "description": "Trip not found"
          }
        }
      },
      "post": {
        "tags": ["Packing List"],
        "summary": "Add a new packing item to a trip",
        "description": "Creates a new packing item and appends it to the trip's packing list.",
        "parameters": [
          {
            "name": "tripId",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "ID of the trip"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["name", "category", "quantity", "requiredStatus", "packedStatus"],
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Passport / ID card"
                },
                "category": {
                  "type": "string",
                  "enum": ["Clothes", "Documents", "Electronics", "Medicine", "Personal", "Other"],
                  "example": "Documents"
                },
                "quantity": {
                  "type": "integer",
                  "minimum": 1,
                  "example": 1
                },
                "requiredStatus": {
                  "type": "string",
                  "enum": ["Required", "Optional"],
                  "example": "Required"
                },
                "packedStatus": {
                  "type": "string",
                  "enum": ["Packed", "Not Packed"],
                  "example": "Not Packed"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Packing item created successfully"
          },
          "400": {
            "description": "Missing/invalid fields or validation error"
          },
          "404": {
            "description": "Trip not found"
          }
        }
      }
    },
