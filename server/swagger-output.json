    "/itinerary/{tripId}": {
      "get": {
        "tags": ["Itinerary"],
        "summary": "Get all itinerary items for a trip",
        "description": "Returns every activity in the itinerary of the specified trip.",
        "parameters": [
          {
            "name": "tripId",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "ID of the trip"
          }
        ],
        "responses": {
          "200": {
            "description": "List of itinerary items"
          },
          "404": {
            "description": "Trip not found"
          }
        }
      },
      "post": {
        "tags": ["Itinerary"],
        "summary": "Add a new itinerary item to a trip",
        "description": "Creates a new activity and appends it to the trip's itinerary.",
        "parameters": [
          {
            "name": "tripId",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "ID of the trip"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["title", "location", "date", "time", "category", "priority", "status"],
              "properties": {
                "title": {
                  "type": "string",
                  "example": "Flight to Da Nang"
                },
                "location": {
                  "type": "string",
                  "example": "Tan Son Nhat Airport"
                },
                "date": {
                  "type": "string",
                  "example": "2026-06-10"
                },
                "time": {
                  "type": "string",
                  "example": "08:00"
                },
                "category": {
                  "type": "string",
                  "enum": ["Transport", "Food", "Sightseeing", "Shopping", "Hotel", "Other"],
                  "example": "Transport"
                },
                "priority": {
                  "type": "string",
                  "enum": ["Low", "Medium", "High"],
                  "example": "High"
                },
                "status": {
                  "type": "string",
                  "enum": ["Planned", "In Progress", "Done"],
                  "example": "Planned"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Itinerary item created successfully"
          },
          "400": {
            "description": "Missing or empty required fields"
          },
          "404": {
            "description": "Trip not found"
          }
        }
      }
